{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vercel.tsbuildinfo",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@vercel/functions", "node"]
  },
  "include": ["middleware.ts", "api/**/*.ts", "auth/**/*.ts"]
}
